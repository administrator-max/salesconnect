#   riwayat perubahan dan harus ikut ter-commit.
# - config.php diabaikan karena berisi hash password + ID spreadsheet.
#   Pakai config.sample.php sebagai acuan; salin ke config.php di server.

# Build artifacts — never commit (may embed config.php)
*_deploy.zip
